{
  "version": 6,
  "configurePresets": [
    {
      "name": "base-clang",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_BUILD_TYPE": "debug",
        "BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "base-debug",
      "hidden": true,
      "inherits": "base-clang",
      "cacheVariables": {}
    },
    {
      "name": "base-test",
      "hidden": true,
      "inherits": "base-clang",
      "cacheVariables": {
        "BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "base-release",
      "hidden": true,
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_BUILD_TYPE": "release",
        "BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "base-arm64",
      "hidden": true,
      "architecture": "arm64",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-linux"
      }
    },
    {
      "name": "debug/jetson",
      "inherits": [
        "base-debug",
        "base-arm64"
      ],
      "cacheVariables": {
        "SST_PLATFORM": "jetson"
      }
    },
    {
      "name": "test/jetson",
      "inherits": [
        "base-test",
        "base-arm64"
      ],
      "cacheVariables": {
        "SST_PLATFORM": "jetson"
      }
    },
    {
      "name": "release/jetson",
      "inherits": [
        "base-release",
        "base-arm64"
      ],
      "cacheVariables": {
        "SST_PLATFORM": "jetson"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug/jetson",
      "configurePreset": "debug/jetson"
    },
    {
      "name": "test/jetson",
      "configurePreset": "test/jetson"
    },
    {
      "name": "release/jetson",
      "configurePreset": "release/jetson"
    }
  ],
  "testPresets": [
    {
      "name": "test/jetson",
      "configurePreset": "test/jetson"
    }
  ]
}