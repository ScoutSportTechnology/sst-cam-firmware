{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "environment": {
        "PATH": "$env{HOME}/.local/bin:$penv{PATH}"
      },
      "cacheVariables": {
        "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "${sourceDir}/cmake/conan_provider.cmake",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CONAN_INSTALL_ARGS": "--build=missing"
      }
    },
    {
      "name": "base-jetson-r36.5",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CONAN_BUILD_PROFILE": "${sourceDir}/conan/profiles/jetson-r36.5",
        "CONAN_HOST_PROFILE": "${sourceDir}/conan/profiles/jetson-r36.5"
      }
    },
    {
      "name": "release/jetson/r36.5",
      "inherits": "base-jetson-r36.5",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug/jetson/r36.5",
      "inherits": "base-jetson-r36.5",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "test/jetson/r36.5",
      "inherits": "base-jetson-r36.5",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SST_ENABLE_TESTS": "ON",
        "CONAN_INSTALL_ARGS": "--build=missing;-o;with_tests=True"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release/jetson/r36.5",
      "configurePreset": "release/jetson/r36.5"
    },
    {
      "name": "debug/jetson/r36.5",
      "configurePreset": "debug/jetson/r36.5"
    },
    {
      "name": "test/jetson/r36.5",
      "configurePreset": "test/jetson/r36.5"
    }
  ],
  "testPresets": [
    {
      "name": "test/jetson/r36.5",
      "configurePreset": "test/jetson/r36.5"
    }
  ]
}