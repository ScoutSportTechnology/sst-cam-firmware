{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "environment": {
        "PATH": "$env{HOME}/.local/bin:$penv{PATH}"
      },
      "cacheVariables": {
        "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "${sourceDir}/cmake/conan_provider.cmake",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CONAN_INSTALL_ARGS": "--build=missing"
      }
    },
    {
      "name": "base-jetson-r36.5-native",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CONAN_BUILD_PROFILE": "${sourceDir}/conan/profiles/jetson-r36.5",
        "CONAN_HOST_PROFILE": "${sourceDir}/conan/profiles/jetson-r36.5"
      }
    },
    {
      "name": "base-jetson-r36.5-cross-wsl-ubuntu",
      "hidden": true,
      "inherits": "base",
      "environment": {
        "PATH": "${sourceDir}/.cache/toolchains/bootlin-jetson-r36/bin:$env{HOME}/.local/bin:$penv{PATH}"
      },
      "cacheVariables": {
        "CONAN_BUILD_PROFILE": "${sourceDir}/conan/profiles/wsl-ubuntu",
        "CONAN_HOST_PROFILE": "${sourceDir}/conan/profiles/jetson-r36.5-cross",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/jetson-r36.5.cmake"
      }
    },
    {
      "name": "base-jetson-r36.5-cross-ubuntu",
      "hidden": true,
      "inherits": "base",
      "environment": {
        "PATH": "${sourceDir}/.cache/toolchains/bootlin-jetson-r36/bin:$env{HOME}/.local/bin:$penv{PATH}"
      },
      "cacheVariables": {
        "CONAN_BUILD_PROFILE": "${sourceDir}/conan/profiles/ubuntu",
        "CONAN_HOST_PROFILE": "${sourceDir}/conan/profiles/jetson-r36.5-cross",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/jetson-r36.5.cmake"
      }
    },
    {
      "name": "native/release/jetson/r36.5",
      "displayName": "Native Release Jetson R36.5",
      "inherits": "base-jetson-r36.5-native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "native/debug/jetson/r36.5",
      "displayName": "Native Debug Jetson R36.5",
      "inherits": "base-jetson-r36.5-native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "native/test/jetson/r36.5",
      "displayName": "Native Test Jetson R36.5",
      "inherits": "base-jetson-r36.5-native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SST_ENABLE_TESTS": "ON",
        "CONAN_INSTALL_ARGS": "--build=missing;-o;with_tests=True"
      }
    },
    {
      "name": "cross/release/jetson/r36.5/wsl-ubuntu",
      "displayName": "Cross Release Jetson R36.5 (WSL Ubuntu)",
      "inherits": "base-jetson-r36.5-cross-wsl-ubuntu",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "cross/debug/jetson/r36.5/wsl-ubuntu",
      "displayName": "Cross Debug Jetson R36.5 (WSL Ubuntu)",
      "inherits": "base-jetson-r36.5-cross-wsl-ubuntu",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "cross/test/jetson/r36.5/wsl-ubuntu",
      "displayName": "Cross Test Jetson R36.5 (WSL Ubuntu)",
      "inherits": "base-jetson-r36.5-cross-wsl-ubuntu",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SST_ENABLE_TESTS": "ON",
        "CONAN_INSTALL_ARGS": "--build=missing;-o;with_tests=True"
      }
    },
    {
      "name": "cross/release/jetson/r36.5/ubuntu",
      "displayName": "Cross Release Jetson R36.5 (Ubuntu)",
      "inherits": "base-jetson-r36.5-cross-ubuntu",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "cross/debug/jetson/r36.5/ubuntu",
      "displayName": "Cross Debug Jetson R36.5 (Ubuntu)",
      "inherits": "base-jetson-r36.5-cross-ubuntu",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "cross/test/jetson/r36.5/ubuntu",
      "displayName": "Cross Test Jetson R36.5 (Ubuntu)",
      "inherits": "base-jetson-r36.5-cross-ubuntu",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SST_ENABLE_TESTS": "ON",
        "CONAN_INSTALL_ARGS": "--build=missing;-o;with_tests=True"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "native/release/jetson/r36.5",
      "configurePreset": "native/release/jetson/r36.5"
    },
    {
      "name": "native/debug/jetson/r36.5",
      "configurePreset": "native/debug/jetson/r36.5"
    },
    {
      "name": "native/test/jetson/r36.5",
      "configurePreset": "native/test/jetson/r36.5"
    },
    {
      "name": "cross/release/jetson/r36.5/wsl-ubuntu",
      "configurePreset": "cross/release/jetson/r36.5/wsl-ubuntu"
    },
    {
      "name": "cross/debug/jetson/r36.5/wsl-ubuntu",
      "configurePreset": "cross/debug/jetson/r36.5/wsl-ubuntu"
    },
    {
      "name": "cross/test/jetson/r36.5/wsl-ubuntu",
      "configurePreset": "cross/test/jetson/r36.5/wsl-ubuntu"
    },
    {
      "name": "cross/release/jetson/r36.5/ubuntu",
      "configurePreset": "cross/release/jetson/r36.5/ubuntu"
    },
    {
      "name": "cross/debug/jetson/r36.5/ubuntu",
      "configurePreset": "cross/debug/jetson/r36.5/ubuntu"
    },
    {
      "name": "cross/test/jetson/r36.5/ubuntu",
      "configurePreset": "cross/test/jetson/r36.5/ubuntu"
    }
  ],
  "testPresets": [
    {
      "name": "native/test/jetson/r36.5",
      "configurePreset": "native/test/jetson/r36.5"
    },
    {
      "name": "cross/test/jetson/r36.5/wsl-ubuntu",
      "configurePreset": "cross/test/jetson/r36.5/wsl-ubuntu"
    },
    {
      "name": "cross/test/jetson/r36.5/ubuntu",
      "configurePreset": "cross/test/jetson/r36.5/ubuntu"
    }
  ]
}