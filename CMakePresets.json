{
  "version": 6,
  "configurePresets": [
    {
      "name": "base-clangcl",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_VISUAL_STUDIO_PATH": "$env{VCPKG_VISUAL_STUDIO_PATH}"
      }
    },
    {
      "name": "base-debug-clangcl",
      "hidden": true,
      "inherits": "base-clangcl",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_BUILD_TYPE": "debug",
        "BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "base-test-clangcl",
      "hidden": true,
      "inherits": "base-clangcl",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_BUILD_TYPE": "debug",
        "BUILD_TESTS": "ON"
      }
    },
    {
      "name": "base-release-clangcl",
      "hidden": true,
      "inherits": "base-clangcl",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_BUILD_TYPE": "release",
        "BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "debug/x64-windows",
      "inherits": "base-debug-clangcl",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "test/x64-windows",
      "inherits": "base-test-clangcl",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "release/x64-windows",
      "inherits": "base-release-clangcl",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug/x64-windows",
      "configurePreset": "debug/x64-windows"
    },
    {
      "name": "test/x64-windows",
      "configurePreset": "test/x64-windows"
    },
    {
      "name": "release/x64-windows",
      "configurePreset": "release/x64-windows"
    }
  ],
  "testPresets": [
    {
      "name": "test/x64-windows",
      "configurePreset": "test/x64-windows"
    }
  ]
}