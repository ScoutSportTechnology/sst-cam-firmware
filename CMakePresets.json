{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/jetson-orin-jetpack_6.2.2-l4t_36.5.0.cmake",
        "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "${sourceDir}/cmake/conan_provider.cmake",
        "CONAN_BUILD_PROFILE": "${sourceDir}/conan/profiles/linux-x86_64-host.profile",
        "CONAN_HOST_PROFILE": "${sourceDir}/conan/profiles/jetson-aarch64-target.profile"
      }
    },
    {
      "name": "release/jetson",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CONAN_INSTALL_ARGS": "--build=missing -s:h build_type=Release"
      }
    },
    {
      "name": "debug/jetson",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CONAN_INSTALL_ARGS": "--build=missing -s:h build_type=Debug"
      }
    },
    {
      "name": "test/jetson",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SST_ENABLE_TESTS": "ON",
        "CONAN_INSTALL_ARGS": "--build=missing -s:h build_type=RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release/jetson",
      "configurePreset": "release/jetson"
    },
    {
      "name": "debug/jetson",
      "configurePreset": "debug/jetson"
    },
    {
      "name": "test/jetson",
      "configurePreset": "test/jetson"
    }
  ],
  "testPresets": [
    {
      "name": "test/jetson",
      "configurePreset": "test/jetson"
    }
  ]
}