{
  // CMake / Conan integration
  "cmake.useCMakePresets": "always",
  "cmake.configureOnOpen": true,
  "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",
  // Let CMake Tools describe the project to tools
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
  // clangd language server from MSYS2 Clang64
  "clangd.path": "C:/msys64/clang64/bin/clangd.exe",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}",
    "--background-index"
  ],
  // Formatting
  "editor.formatOnSave": true,
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "testMate.cpp.debug.configTemplate": {
    "name": "Debug (Conan Cmake MSYS2 Clang64)",
    "type": "lldb",
    "request": "launch",
    "program": "${workspaceFolder}/build/debug/bin/sst_cam_firmware_tests",
    "args": [],
    "cwd": "${workspaceFolder}",
    "env": {
      "PATH": "C:/msys64/clang64/bin;${env:PATH}"
    },
    "preRunCommands": [],
    "preLaunchTask": "build-test"
  },
}