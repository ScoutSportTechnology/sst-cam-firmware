{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "preset",
      "type": "pickString",
      "description": "CMake preset",
      "options": [
        "debug-x64-windows",
        "test-x64-windows",
        "release-x64-windows",
        "debug-x86-windows",
        "test-x86-windows",
        "release-x86-windows",
        "debug-arm64-windows",
        "test-arm64-windows",
        "release-arm64-windows",
        "debug-arm-windows",
        "test-arm-windows",
        "release-arm-windows"
      ]
    },
    {
      "id": "host_arch",
      "type": "pickString",
      "description": "Host tools arch",
      "options": [
        "amd64",
        "x86",
        "arm64",
        "arm"
      ]
    }
  ],
  "windows": {
    "options": {
      "shell": {
        "executable": "cmd.exe",
        "args": [
          "/C",
          "${workspaceFolder}\\scripts\\task_parse.cmd ${input:preset}",
          "&&",
          "echo target_arch=%target_arch%",
          "&&",
          "\"C:/Program Files/Microsoft Visual Studio/18/Community/Common7/Tools/VsDevCmd.bat\"",
          "-arch=%target_arch%",
          "-host_arch=${input:host_arch}",
          "&&"
        ]
      }
    }
  },
  "tasks": [
    {
      "label": "configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "${input:preset}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "${input:preset}"
      ],
      "dependsOn": [
        "configure"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "clean",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "${input:preset}",
        "--target",
        "clean"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}