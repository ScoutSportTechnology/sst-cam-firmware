{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "deps-debug",
      "type": "shell",
      "command": "conan install -pr cmake/conan/profiles/msys2/clang64/debug.profile -b missing .",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "configure-debug",
      "type": "shell",
      "command": "cmake --preset conan-debug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "deps-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "clean-debug",
      "type": "shell",
      "command": "cmake --build --preset conan-debug --target clean",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "configure-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "build-debug",
      "type": "shell",
      "command": "cmake --build --preset conan-debug --target sst_cam_firmware",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "configure-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "deps-release",
      "type": "shell",
      "command": "conan install -pr cmake/conan/profiles/msys2/clang64/release.profile -b missing .",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "configure-release",
      "type": "shell",
      "command": "cmake --preset conan-release",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "deps-release"
      ],
      "problemMatcher": []
    },
    {
      "label": "build-release",
      "type": "shell",
      "command": "cmake --build --preset conan-release --target sst_cam_firmware",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "configure-release"
      ],
      "problemMatcher": []
    },
    {
      "label": "configure-test",
      "type": "shell",
      "command": "cmake --preset conan-debug -DBUILD_TESTS=ON",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "deps-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "clean-test",
      "type": "shell",
      "command": "cmake --build --preset conan-debug --target clean",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "configure-test"
      ],
      "problemMatcher": []
    },
    {
      "label": "build-test",
      "type": "shell",
      "command": "cmake --build --preset conan-debug --target sst_cam_firmware_tests",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "clean-test"
      ],
      "problemMatcher": []
    },
  ]
}